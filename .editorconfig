root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
max_line_length = 120

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{kt,kts}]
# Compose 관례: @Composable 함수는 PascalCase — ktlint function-naming 예외
ktlint_function_naming_ignore_when_annotated_with = Composable
